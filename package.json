{
  "name": "kronos-agent",
  "version": "0.1.0",
  "description": "⌛ Time to ship - AI agent that transforms your releases into content for every platform",
  "main": "dist/index.js",
  "bin": {
    "kronos": "./dist/cli.js"
  },
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
