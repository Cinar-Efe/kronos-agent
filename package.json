    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "release",
    "changelog",
    "automation",
    "content-generation",
    "devtools",
    "openai",
    "git",
    "ship",
    "cli",
    "typescript",
    "kronos"
  ],
  "author": "Cinar Efe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cinar-Efe/kronos-agent.git"
  },
  "bugs": {
    "url": "https://github.com/Cinar-Efe/kronos-agent/issues"
  },
  "homepage": "https://github.com/Cinar-Efe/kronos-agent#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "openai": "^4.28.0",
    "simple-git": "^3.22.0",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.14",
    "dotenv": "^16.4.1",
    "fs-extra": "^11.2.0",
    "conventional-commits-parser": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/inquirer": "^9.0.7",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0"
  }
